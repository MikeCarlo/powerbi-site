---
import BaseLayout from './BaseLayout.astro';
import { Image } from 'astro:assets';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const { entry, prev, next, morePosts } = Astro.props;
const { title, date, authors, categories, tags, featuredImage, excerpt } = entry.data;

const slug = entry.id.replace(/\/index\.mdx?$/, '').replace(/\.mdx?$/, '');
const articleUrl = `https://powerbi.tips/${slug}/`;

// Build Article JSON-LD
const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: excerpt || '',
  url: articleUrl,
  datePublished: date.toISOString(),
  dateModified: date.toISOString(),
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
  publisher: {
    '@type': 'Organization',
    name: 'PowerBI.tips',
    url: 'https://powerbi.tips',
    logo: { '@type': 'ImageObject', url: `https://powerbi.tips${base}/favicon.svg` },
  },
  ...(authors?.length && {
    author: authors.map((a) => ({ '@type': 'Person', name: a })),
  }),
  ...(featuredImage && {
    image: typeof featuredImage === 'string'
      ? `https://powerbi.tips${featuredImage}`
      : undefined,
  }),
  ...(categories?.length && { articleSection: categories }),
  ...(tags?.length && { keywords: tags.join(', ') }),
};
---

<BaseLayout title={`${title} | PowerBI.tips`} description={excerpt ?? ''} jsonLd={articleJsonLd}>
  <article class="max-w-none space-y-6 text-[1.05rem] leading-relaxed">
    <h1 class="text-4xl font-semibold tracking-tight text-neutral-900">{title}</h1>
    
    <div class="flex flex-wrap items-center gap-4 text-sm text-neutral-500">
      <span>{date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
      {authors?.length && (
        <span>
          By {authors.map((author, i) => (
            <>
              <a 
                href={`${base}/author/${author.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')}/`}
                class="text-blue-600 hover:text-blue-700"
              >
                {author}
              </a>
              {i < authors.length - 1 ? ', ' : ''}
            </>
          ))}
        </span>
      )}
    </div>

    {categories?.length ? (
      <div class="flex flex-wrap gap-2">
        {categories.map((category) => (
          <a
            class="rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-blue-700"
            href={`${base}/category/${category.toLowerCase().replace(/\s+/g, '-')}/`}
          >
            {category}
          </a>
        ))}
      </div>
    ) : null}

    {featuredImage && (
      <Image 
        src={featuredImage} 
        alt={title} 
        class="w-full rounded-xl object-cover"
        widths={[400, 800, 1200]}
        sizes="(max-width: 800px) 100vw, 800px"
      />
    )}

    <div class="prose" data-anchor-links>
      <slot />
    </div>

    <script is:inline>
      (function () {
        function toFullUrl(hash) {
          const url = new URL(window.location.href);
          url.hash = hash;
          return url.toString();
        }

        async function copyText(text) {
          try {
            await navigator.clipboard.writeText(text);
            return true;
          } catch (e) {
            // Fallback
            try {
              const ta = document.createElement('textarea');
              ta.value = text;
              ta.setAttribute('readonly', '');
              ta.style.position = 'fixed';
              ta.style.top = '-9999px';
              document.body.appendChild(ta);
              ta.select();
              document.execCommand('copy');
              document.body.removeChild(ta);
              return true;
            } catch (_e) {
              return false;
            }
          }
        }

        function linkIconSvg() {
          return `
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M10 13a5 5 0 0 1 0-7l1-1a5 5 0 0 1 7 7l-1 1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M14 11a5 5 0 0 1 0 7l-1 1a5 5 0 0 1-7-7l1-1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>`;
        }

        function makeCopyButton(hash, label) {
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'anchor-copy-btn';
          btn.setAttribute('aria-label', label);
          btn.title = label;
          btn.innerHTML = linkIconSvg();
          // Inline styles as a safety net (Astro scoped CSS won’t style injected elements)
          btn.style.display = 'inline-flex';
          btn.style.alignItems = 'center';
          btn.style.justifyContent = 'center';
          btn.style.width = '1.1rem';
          btn.style.height = '1.1rem';
          btn.style.marginLeft = '0.5rem';
          btn.style.border = '0';
          btn.style.background = 'transparent';
          btn.style.cursor = 'pointer';
          btn.addEventListener('click', async (ev) => {
            ev.preventDefault();
            const full = toFullUrl(hash);
            // Update URL fragment so the page deep link is visible
            try { window.location.hash = hash; } catch (_e) {}
            const ok = await copyText(full);
            btn.setAttribute('data-copied', ok ? '1' : '0');
            window.setTimeout(() => btn.removeAttribute('data-copied'), 1200);
          });
          return btn;
        }

        function normalizeTimestampId(text) {
          // Keep exactly M:SS or H:MM:SS (to match the URL example like #2:33)
          const t = (text || '').trim();
          if (/^\d{1,2}:\d{2}(:\d{2})?$/.test(t)) return t;
          return null;
        }

        function run() {
          const root = document.querySelector('[data-anchor-links]');
          if (!root) return;

          // 1) Add copy-link buttons to headings (h2-h6)
          const headings = root.querySelectorAll('h2[id], h3[id], h4[id], h5[id], h6[id]');
          headings.forEach((h) => {
            if (h.querySelector('.anchor-copy-btn')) return;
            const id = h.getAttribute('id');
            if (!id) return;
            h.classList.add('anchor-heading');
            const btn = makeCopyButton(id, 'Copy link to this section');
            btn.classList.add('anchor-copy-btn--heading');
            h.appendChild(btn);
          });

          // 2) Add deep-link copy buttons next to transcript timestamps
          const tsLinks = root.querySelectorAll('a[href*="youtube.com/watch"][href*="&t="]');
          tsLinks.forEach((a) => {
            const ts = normalizeTimestampId(a.textContent);
            if (!ts) return;

            // Ensure there is an element with the matching id to deep-link to
            if (!a.id) a.id = ts;

            // Avoid duplicates
            if (a.nextElementSibling && a.nextElementSibling.classList && a.nextElementSibling.classList.contains('anchor-copy-btn')) return;

            const btn = makeCopyButton(ts, 'Copy link to this timestamp');
            btn.classList.add('anchor-copy-btn--timestamp');
            a.insertAdjacentElement('afterend', btn);
          });
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', run);
        } else {
          run();
        }
      })();
    </script>

    <style is:global>
      /* Anchor copy button (headings + timestamps) */
      .anchor-heading { position: relative; }
      .anchor-copy-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1.1rem;
        height: 1.1rem;
        margin-left: 0.5rem;
        border: 0;
        background: transparent;
        color: rgb(107 114 128); /* neutral-500 */
        cursor: pointer;
        opacity: 0.35;
        transform: translateY(1px);
        transition: opacity 120ms ease, color 120ms ease;
        vertical-align: middle;
      }
      .anchor-copy-btn svg { width: 1.1rem; height: 1.1rem; }

      /* Show on hover for headings */
      .anchor-heading:hover .anchor-copy-btn--heading,
      .anchor-copy-btn--heading:focus-visible {
        opacity: 1;
      }

      /* Timestamp buttons: keep subtle, show when hovering the paragraph line */
      .prose p:hover .anchor-copy-btn--timestamp,
      .anchor-copy-btn--timestamp:focus-visible {
        opacity: 1;
      }

      .anchor-copy-btn:hover { color: rgb(37 99 235); /* blue-600 */ }

      /* simple copied feedback */
      .anchor-copy-btn[data-copied="1"] { opacity: 1; color: rgb(22 163 74); /* green-600 */ }
      .anchor-copy-btn[data-copied="0"] { opacity: 1; color: rgb(220 38 38); /* red-600 */ }

      /* On touch devices there is no hover — show buttons by default */
      @media (hover: none) {
        .anchor-copy-btn { opacity: 1; }
      }

      /* For users with reduced motion */
      @media (prefers-reduced-motion: reduce) {
        .anchor-copy-btn { transition: none; }
      }
    </style>

    {tags?.length ? (
      <div class="mt-8 flex flex-wrap gap-2">
        {tags.map((tag) => (
          <a 
            href={`${base}/tag/${tag.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')}/`}
            class="rounded-full border border-neutral-200 px-3 py-1 text-xs text-neutral-500 hover:border-blue-300 hover:bg-blue-50 hover:text-blue-700 transition-colors"
          >
            #{tag}
          </a>
        ))}
      </div>
    ) : null}
  </article>

  <div class="mt-12 grid gap-6 border-t border-neutral-200 pt-8 md:grid-cols-2">
    <div>
      <p class="text-xs font-semibold uppercase tracking-wide text-neutral-500">Previous</p>
      {prev ? (
        <a class="mt-2 block text-lg font-semibold text-blue-600 hover:text-blue-700" href={`${base}/${prev.slug}/`}>
          {prev.data.title}
        </a>
      ) : (
        <p class="mt-2 text-sm text-neutral-500">No previous post</p>
      )}
    </div>
    <div class="md:text-right">
      <p class="text-xs font-semibold uppercase tracking-wide text-neutral-500">Next</p>
      {next ? (
        <a class="mt-2 block text-lg font-semibold text-blue-600 hover:text-blue-700" href={`${base}/${next.slug}/`}>
          {next.data.title}
        </a>
      ) : (
        <p class="mt-2 text-sm text-neutral-500">No next post</p>
      )}
    </div>
  </div>

  {morePosts?.length ? (
    <section class="mt-12">
      <h2 class="text-xl font-semibold">More Posts</h2>
      <div class="mt-6 grid gap-6 md:grid-cols-3">
        {morePosts.map((post) => (
          <article class="rounded-xl border border-neutral-200 p-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-neutral-500">
              {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
            </p>
            <h3 class="mt-2 text-lg font-semibold">
              <a class="text-blue-600 hover:text-blue-700" href={`${base}/${post.slug}/`}>
                {post.data.title}
              </a>
            </h3>
            {post.data.excerpt && <p class="mt-2 text-sm text-neutral-600">{post.data.excerpt}</p>}
          </article>
        ))}
      </div>
    </section>
  ) : null}
</BaseLayout>
