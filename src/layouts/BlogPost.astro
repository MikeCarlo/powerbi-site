---
import BaseLayout from './BaseLayout.astro';
import { Image } from 'astro:assets';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const { entry, prev, next, morePosts, faqItems = [], howToSteps = [] } = Astro.props;
const { title, date, authors, categories, tags, featuredImage, excerpt } = entry.data;

const slug = entry.id.replace(/\/index\.mdx?$/, '').replace(/\.mdx?$/, '');
const articleUrl = `https://powerbi.tips/${slug}/`;

// Build Article JSON-LD
const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: excerpt || '',
  url: articleUrl,
  datePublished: date.toISOString(),
  dateModified: date.toISOString(),
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
  publisher: {
    '@type': 'Organization',
    name: 'PowerBI.tips',
    url: 'https://powerbi.tips',
    logo: { '@type': 'ImageObject', url: `https://powerbi.tips${base}/favicon.svg` },
  },
  ...(authors?.length && {
    author: authors.map((a) => ({ '@type': 'Person', name: a })),
  }),
  ...(featuredImage && {
    image: typeof featuredImage === 'string'
      ? `https://powerbi.tips${featuredImage}`
      : undefined,
  }),
  ...(categories?.length && { articleSection: categories }),
  ...(tags?.length && { keywords: tags.join(', ') }),
};

// BreadcrumbList JSON-LD
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: 'https://powerbi.tips/',
    },
    ...(categories?.length ? [{
      '@type': 'ListItem',
      position: 2,
      name: categories[0],
      item: `https://powerbi.tips/category/${categories[0].toLowerCase().replace(/\s+/g, '-')}/`,
    }] : []),
    {
      '@type': 'ListItem',
      position: categories?.length ? 3 : 2,
      name: title,
      item: articleUrl,
    },
  ],
};

// FAQ JSON-LD (from faqItems prop — generated at page level)
const faqJsonLd = faqItems.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
} : null;

// HowTo JSON-LD (from howToSteps prop — generated at page level for tutorial posts)
const howToJsonLd = howToSteps.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: title,
  description: excerpt || '',
  step: howToSteps.map((step, i) => ({
    '@type': 'HowToStep',
    position: i + 1,
    name: step.name,
    text: step.text,
    ...(step.url ? { url: step.url } : {}),
  })),
} : null;

// Collect all JSON-LD schemas
const allJsonLd = [
  articleJsonLd,
  breadcrumbJsonLd,
  ...(faqJsonLd ? [faqJsonLd] : []),
  ...(howToJsonLd ? [howToJsonLd] : []),
];
---

<BaseLayout title={`${title} | PowerBI.tips`} description={excerpt ?? ''} jsonLd={allJsonLd}>
  <article class="max-w-none space-y-6 text-[1.05rem] leading-relaxed">
    <h1 class="text-4xl font-semibold tracking-tight text-neutral-900">{title}</h1>
    
    <div class="flex flex-wrap items-center gap-4 text-sm text-neutral-500">
      <span>{date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
      {authors?.length && (
        <span>
          By {authors.map((author, i) => (
            <>
              <a 
                href={`${base}/author/${author.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')}/`}
                class="text-blue-600 hover:text-blue-700"
              >
                {author}
              </a>
              {i < authors.length - 1 ? ', ' : ''}
            </>
          ))}
        </span>
      )}
    </div>

    {categories?.length ? (
      <div class="flex flex-wrap gap-2">
        {categories.map((category) => (
          <a
            class="rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-blue-700"
            href={`${base}/category/${category.toLowerCase().replace(/\s+/g, '-')}/`}
          >
            {category}
          </a>
        ))}
      </div>
    ) : null}

    {featuredImage && (
      <Image 
        src={featuredImage} 
        alt={title} 
        class="w-full rounded-xl object-cover"
        widths={[400, 800, 1200]}
        sizes="(max-width: 800px) 100vw, 800px"
      />
    )}

    <div class="prose" data-anchor-links>
      <slot />
    </div>

    <script is:inline>
      (function () {
        let __anchorBtnId = 0;
        function toFullUrl(hash) {
          const url = new URL(window.location.href);
          url.hash = hash;
          return url.toString();
        }

        async function copyText(text) {
          try {
            await navigator.clipboard.writeText(text);
            return true;
          } catch (e) {
            // Fallback
            try {
              const ta = document.createElement('textarea');
              ta.value = text;
              ta.setAttribute('readonly', '');
              ta.style.position = 'fixed';
              ta.style.top = '-9999px';
              document.body.appendChild(ta);
              ta.select();
              document.execCommand('copy');
              document.body.removeChild(ta);
              return true;
            } catch (_e) {
              return false;
            }
          }
        }
        function linkIconSvg(id) {
          const gradId = `pbitips-link-grad-${id}`;
          const hoverSvg = `<svg width="86" height="86" viewBox="0 0 86 86" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M41.7906 17.6031L48.5094 10.8844C50.2563 9.13737 52.3303 7.75158 54.6129 6.80611C56.8954 5.86065 59.3419 5.37402 61.8125 5.37402C64.2831 5.37402 66.7295 5.86065 69.0121 6.80611C71.2946 7.75158 73.3686 9.13737 75.1156 10.8844C76.8626 12.6313 78.2484 14.7053 79.1939 16.9879C80.1393 19.2704 80.6259 21.7169 80.6259 24.1875C80.6259 26.6581 80.1393 29.1045 79.1939 31.3871C78.2484 33.6696 76.8626 35.7436 75.1156 37.4906L61.6781 50.9281C59.9312 52.6752 57.8572 54.0611 55.5747 55.0066C53.2921 55.9522 50.8456 56.4388 48.375 56.4388C45.9043 56.4388 43.4579 55.9522 41.1753 55.0066C38.8927 54.0611 36.8188 52.6752 35.0719 50.9281C34.3602 50.1635 33.9726 49.1527 33.9906 48.1082C34.0087 47.0638 34.4309 46.067 35.1686 45.3274C35.9082 44.5897 36.905 44.1674 37.9495 44.1494C38.9939 44.1314 40.0047 44.5189 40.7694 45.2306C41.767 46.2314 42.9524 47.0254 44.2575 47.5672C45.5626 48.109 46.9619 48.3879 48.375 48.3879C49.7881 48.3879 51.1873 48.109 52.4924 47.5672C53.7976 47.0254 54.9829 46.2314 55.9806 45.2306L69.4181 31.7931C71.3371 29.7563 72.3871 27.052 72.3455 24.2538C72.3038 21.4557 71.1737 18.7839 69.1949 16.8051C67.2161 14.8263 64.5443 13.6962 61.7461 13.6545C58.948 13.6128 56.2437 14.6629 54.2069 16.5819L47.4881 23.3006C46.7235 24.0123 45.7127 24.3999 44.6682 24.3818C43.6238 24.3638 42.627 23.9415 41.8874 23.2039C41.1497 22.4642 40.7274 21.4675 40.7094 20.423C40.6914 19.3785 41.0789 18.3678 41.7906 17.6031ZM16.5819 69.4181C17.5795 70.4189 18.7649 71.2129 20.07 71.7547C21.3751 72.2965 22.7744 72.5754 24.1875 72.5754C25.6006 72.5754 26.9998 72.2965 28.3049 71.7547C29.6101 71.2129 30.7954 70.4189 31.7931 69.4181L38.5119 62.6994C39.2765 61.9877 40.2873 61.6001 41.3317 61.6181C42.3762 61.6362 43.373 62.0584 44.1126 62.7961C44.8503 63.5357 45.2725 64.5325 45.2906 65.577C45.3086 66.6214 44.9211 67.6322 44.2094 68.3969L37.4906 75.1156C35.7436 76.8626 33.6696 78.2484 31.3871 79.1939C29.1045 80.1393 26.6581 80.6259 24.1875 80.6259C19.1978 80.6259 14.4126 78.6438 10.8844 75.1156C7.35615 71.5874 5.37402 66.8021 5.37402 61.8125C5.37402 56.8228 7.35615 52.0376 10.8844 48.5094L24.3219 35.0719C26.0688 33.3248 28.1427 31.9389 30.4253 30.9933C32.7079 30.0478 35.1543 29.5611 37.625 29.5611C40.0956 29.5611 42.5421 30.0478 44.8247 30.9933C47.1072 31.9389 49.1812 33.3248 50.9281 35.0719C51.6398 35.8365 52.0274 36.8473 52.0093 37.8917C51.9913 38.9362 51.569 39.933 50.8314 40.6726C50.0917 41.4103 49.0949 41.8325 48.0505 41.8506C47.006 41.8686 45.9953 41.4811 45.2306 40.7694C44.2329 39.7686 43.0476 38.9745 41.7424 38.4327C40.4373 37.8909 39.0381 37.6121 37.625 37.6121C36.2119 37.6121 34.8126 37.8909 33.5075 38.4327C32.2024 38.9745 31.017 39.7686 30.0194 40.7694L16.5819 54.2069C15.5811 55.2045 14.787 56.3899 14.2452 57.695C13.7034 59.0001 13.4246 60.3994 13.4246 61.8125C13.4246 63.2256 13.7034 64.6248 14.2452 65.9299C14.787 67.2351 15.5811 68.4204 16.5819 69.4181Z" fill="url(#__GRAD_ID__)"/>
<defs>
<linearGradient id="__GRAD_ID__" x1="43" y1="5.37402" x2="43" y2="80.6259" gradientUnits="userSpaceOnUse">
<stop stop-color="#2F96F3"/>
<stop offset="1" stop-color="#A18AF3"/>
</linearGradient>
</defs>
</svg>`.replaceAll('__GRAD_ID__', gradId);
          return `
            <span class="anchor-icon">
              <span class="anchor-icon--idle"><svg width="86" height="86" viewBox="0 0 86 86" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M41.7906 17.6031L48.5094 10.8844C50.2563 9.13737 52.3303 7.75158 54.6129 6.80611C56.8954 5.86065 59.3419 5.37402 61.8125 5.37402C64.2831 5.37402 66.7295 5.86065 69.0121 6.80611C71.2946 7.75158 73.3686 9.13737 75.1156 10.8844C76.8626 12.6313 78.2484 14.7053 79.1939 16.9879C80.1393 19.2704 80.6259 21.7169 80.6259 24.1875C80.6259 26.6581 80.1393 29.1045 79.1939 31.3871C78.2484 33.6696 76.8626 35.7436 75.1156 37.4906L61.6781 50.9281C59.9312 52.6752 57.8572 54.0611 55.5747 55.0066C53.2921 55.9522 50.8456 56.4388 48.375 56.4388C45.9043 56.4388 43.4579 55.9522 41.1753 55.0066C38.8927 54.0611 36.8188 52.6752 35.0719 50.9281C34.3602 50.1635 33.9726 49.1527 33.9906 48.1082C34.0087 47.0638 34.4309 46.067 35.1686 45.3274C35.9082 44.5897 36.905 44.1674 37.9495 44.1494C38.9939 44.1314 40.0047 44.5189 40.7694 45.2306C41.767 46.2314 42.9524 47.0254 44.2575 47.5672C45.5626 48.109 46.9619 48.3879 48.375 48.3879C49.7881 48.3879 51.1873 48.109 52.4924 47.5672C53.7976 47.0254 54.9829 46.2314 55.9806 45.2306L69.4181 31.7931C71.3371 29.7563 72.3871 27.052 72.3455 24.2538C72.3038 21.4557 71.1737 18.7839 69.1949 16.8051C67.2161 14.8263 64.5443 13.6962 61.7461 13.6545C58.948 13.6128 56.2437 14.6629 54.2069 16.5819L47.4881 23.3006C46.7235 24.0123 45.7127 24.3999 44.6682 24.3818C43.6238 24.3638 42.627 23.9415 41.8874 23.2039C41.1497 22.4642 40.7274 21.4675 40.7094 20.423C40.6914 19.3785 41.0789 18.3678 41.7906 17.6031ZM16.5819 69.4181C17.5795 70.4189 18.7649 71.2129 20.07 71.7547C21.3751 72.2965 22.7744 72.5754 24.1875 72.5754C25.6006 72.5754 26.9998 72.2965 28.3049 71.7547C29.6101 71.2129 30.7954 70.4189 31.7931 69.4181L38.5119 62.6994C39.2765 61.9877 40.2873 61.6001 41.3317 61.6181C42.3762 61.6362 43.373 62.0584 44.1126 62.7961C44.8503 63.5357 45.2725 64.5325 45.2906 65.577C45.3086 66.6214 44.9211 67.6322 44.2094 68.3969L37.4906 75.1156C35.7436 76.8626 33.6696 78.2484 31.3871 79.1939C29.1045 80.1393 26.6581 80.6259 24.1875 80.6259C19.1978 80.6259 14.4126 78.6438 10.8844 75.1156C7.35615 71.5874 5.37402 66.8021 5.37402 61.8125C5.37402 56.8228 7.35615 52.0376 10.8844 48.5094L24.3219 35.0719C26.0688 33.3248 28.1427 31.9389 30.4253 30.9933C32.7079 30.0478 35.1543 29.5611 37.625 29.5611C40.0956 29.5611 42.5421 30.0478 44.8247 30.9933C47.1072 31.9389 49.1812 33.3248 50.9281 35.0719C51.6398 35.8365 52.0274 36.8473 52.0093 37.8917C51.9913 38.9362 51.569 39.933 50.8314 40.6726C50.0917 41.4103 49.0949 41.8325 48.0505 41.8506C47.006 41.8686 45.9953 41.4811 45.2306 40.7694C44.2329 39.7686 43.0476 38.9745 41.7424 38.4327C40.4373 37.8909 39.0381 37.6121 37.625 37.6121C36.2119 37.6121 34.8126 37.8909 33.5075 38.4327C32.2024 38.9745 31.017 39.7686 30.0194 40.7694L16.5819 54.2069C15.5811 55.2045 14.787 56.3899 14.2452 57.695C13.7034 59.0001 13.4246 60.3994 13.4246 61.8125C13.4246 63.2256 13.7034 64.6248 14.2452 65.9299C14.787 67.2351 15.5811 68.4204 16.5819 69.4181Z" fill="#B8B8B8"/>
</svg></span>
              <span class="anchor-icon--hover">${hoverSvg}</span>
            </span>`;
        }

        function makeCopyButton(hash, label) {
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'anchor-copy-btn';
          btn.setAttribute('aria-label', label);
          btn.title = label;
          const id = (++__anchorBtnId);
          btn.innerHTML = linkIconSvg(id);
          // Inline styles as a safety net (Astro scoped CSS won’t style injected elements)
          btn.style.display = 'inline-flex';
          btn.style.alignItems = 'center';
          btn.style.justifyContent = 'center';
          btn.style.width = '1.45rem';
          btn.style.height = '1.45rem';
          btn.style.marginLeft = '0.4rem';
          btn.style.border = '0';
          btn.style.background = 'transparent';
          btn.style.cursor = 'pointer';
          btn.addEventListener('click', async (ev) => {
            ev.preventDefault();
            const full = toFullUrl(hash);
            // Update URL fragment so the page deep link is visible
            try { window.location.hash = hash; } catch (_e) {}
            const ok = await copyText(full);
            btn.setAttribute('data-copied', ok ? '1' : '0');
            window.setTimeout(() => btn.removeAttribute('data-copied'), 1200);
          });
          return btn;
        }

        function normalizeTimestampId(text) {
          // Keep exactly M:SS or H:MM:SS (to match the URL example like #2:33)
          const t = (text || '').trim();
          if (/^\d{1,2}:\d{2}(:\d{2})?$/.test(t)) return t;
          return null;
        }

        function run() {
          const root = document.querySelector('[data-anchor-links]');
          if (!root) return;

          // 1) Add copy-link buttons to headings (h2-h6)
          const headings = root.querySelectorAll('h2[id], h3[id], h4[id], h5[id], h6[id]');
          headings.forEach((h) => {
            if (h.querySelector('.anchor-copy-btn')) return;
            const id = h.getAttribute('id');
            if (!id) return;
            h.classList.add('anchor-heading');
            const btn = makeCopyButton(id, 'Copy link to this section');
            btn.classList.add('anchor-copy-btn--heading');
            // Put icon at the end of the heading text
            btn.style.marginLeft = '0.35rem';
            btn.style.marginRight = '0';
            h.appendChild(btn);
          });

          // 2) Add deep-link copy buttons next to transcript timestamps
          const tsLinks = root.querySelectorAll('a[href*="youtube.com/watch"][href*="&t="]');
          tsLinks.forEach((a) => {
            const ts = normalizeTimestampId(a.textContent);
            if (!ts) return;

            // Ensure there is an element with the matching id to deep-link to
            if (!a.id) a.id = ts;

            // Avoid duplicates
            if (a.nextElementSibling && a.nextElementSibling.classList && a.nextElementSibling.classList.contains('anchor-copy-btn')) return;

            const btn = makeCopyButton(ts, 'Copy link to this timestamp');
            btn.classList.add('anchor-copy-btn--timestamp');
            btn.style.marginLeft = '0.4rem';
            btn.style.marginRight = '0';
            a.insertAdjacentElement('afterend', btn);
          });
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', run);
        } else {
          run();
        }
      })();
    </script>

    <style is:global>
      /* Anchor copy button (headings + timestamps) */
      .anchor-heading { position: relative; }
      .anchor-copy-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1.45rem;
        height: 1.45rem;
        margin-left: 0.5rem;
        border: 0;
        background: transparent;
        color: rgb(107 114 128); /* neutral-500 */
        cursor: pointer;
        opacity: 1;
        transform: translateY(1px);
        transition: opacity 120ms ease, color 120ms ease;
        vertical-align: middle;
      }


      /* Icon sizing + idle/hover swap */
      .anchor-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1.45rem;
        height: 1.45rem;
      }
      .anchor-icon svg {
        width: 100%;
        height: 100%;
        display: block;
      }
      .anchor-icon--hover { display: none; }
      .anchor-copy-btn:hover .anchor-icon--idle,
      .anchor-copy-btn:focus-visible .anchor-icon--idle {
        display: none;
      }
      .anchor-copy-btn:hover .anchor-icon--hover,
      .anchor-copy-btn:focus-visible .anchor-icon--hover {
        display: inline-flex;
      }

      /* Show on hover for headings */
      .anchor-heading:hover .anchor-copy-btn--heading,
      .anchor-copy-btn--heading:focus-visible {
        opacity: 1;
      }

      /* Timestamp buttons: keep subtle, show when hovering the paragraph line */
      .prose p:hover .anchor-copy-btn--timestamp,
      .anchor-copy-btn--timestamp:focus-visible {
        opacity: 1;
      }

      /* simple copied feedback */
      .anchor-copy-btn[data-copied="1"] { opacity: 1; color: rgb(22 163 74); /* green-600 */ }
      .anchor-copy-btn[data-copied="0"] { opacity: 1; color: rgb(220 38 38); /* red-600 */ }

      /* On touch devices there is no hover — show buttons by default */
      @media (hover: none) {
        .anchor-copy-btn { opacity: 1; }
      }

      /* For users with reduced motion */
      @media (prefers-reduced-motion: reduce) {
        .anchor-copy-btn { transition: none; }
      }
    </style>

    {tags?.length ? (
      <div class="mt-8 flex flex-wrap gap-2">
        {tags.map((tag) => (
          <a 
            href={`${base}/tag/${tag.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')}/`}
            class="rounded-full border border-neutral-200 px-3 py-1 text-xs text-neutral-500 hover:border-blue-300 hover:bg-blue-50 hover:text-blue-700 transition-colors"
          >
            #{tag}
          </a>
        ))}
      </div>
    ) : null}
  </article>

  <div class="mt-12 grid gap-6 border-t border-neutral-200 pt-8 md:grid-cols-2">
    <div>
      <p class="text-xs font-semibold uppercase tracking-wide text-neutral-500">Previous</p>
      {prev ? (
        <a class="mt-2 block text-lg font-semibold text-blue-600 hover:text-blue-700" href={`${base}/${prev.slug}/`}>
          {prev.data.title}
        </a>
      ) : (
        <p class="mt-2 text-sm text-neutral-500">No previous post</p>
      )}
    </div>
    <div class="md:text-right">
      <p class="text-xs font-semibold uppercase tracking-wide text-neutral-500">Next</p>
      {next ? (
        <a class="mt-2 block text-lg font-semibold text-blue-600 hover:text-blue-700" href={`${base}/${next.slug}/`}>
          {next.data.title}
        </a>
      ) : (
        <p class="mt-2 text-sm text-neutral-500">No next post</p>
      )}
    </div>
  </div>

  {morePosts?.length ? (
    <section class="mt-12">
      <h2 class="text-xl font-semibold">More Posts</h2>
      <div class="mt-6 grid gap-6 md:grid-cols-3">
        {morePosts.map((post) => (
          <article class="rounded-xl border border-neutral-200 p-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-neutral-500">
              {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
            </p>
            <h3 class="mt-2 text-lg font-semibold">
              <a class="text-blue-600 hover:text-blue-700" href={`${base}/${post.slug}/`}>
                {post.data.title}
              </a>
            </h3>
            {post.data.excerpt && <p class="mt-2 text-sm text-neutral-600">{post.data.excerpt}</p>}
          </article>
        ))}
      </div>
    </section>
  ) : null}
</BaseLayout>
