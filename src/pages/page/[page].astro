---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const PAGE_SIZE = 24;

export async function getStaticPaths() {
  // NOTE: Astro has historically been picky about module-scope constants inside
  // getStaticPaths after compilation, so we keep the literal scoped here too.
  const pageSize = 24;

  const posts = await getCollection('blog');
  const totalPages = Math.max(1, Math.ceil(posts.length / pageSize));

  return Array.from({ length: totalPages }, (_, i) => ({
    params: { page: String(i + 1) },
  }));
}

const pageNum = Number(Astro.params.page ?? '1');

const allPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .map((post) => ({
    ...post,
    slug: post.id.replace(/\/index\.mdx?$/, '').replace(/\.mdx?$/, ''),
  }));

const totalPages = Math.max(1, Math.ceil(allPosts.length / PAGE_SIZE));
const safePage = Number.isFinite(pageNum) && pageNum >= 1 && pageNum <= totalPages ? pageNum : 1;

const start = (safePage - 1) * PAGE_SIZE;
const posts = allPosts.slice(start, start + PAGE_SIZE);

const prevUrl = safePage > 1 ? `${base}/page/${safePage - 1}/` : `${base}/`;
const nextUrl = safePage < totalPages ? `${base}/page/${safePage + 1}/` : null;
---

<BaseLayout title={`Posts – Page ${safePage} | PowerBI.tips`} description={`Browse posts – page ${safePage} of ${totalPages}.`}>
  <section class="mb-10">
    <h1 class="text-3xl font-semibold">Posts – Page {safePage}</h1>
    <p class="mt-2 text-neutral-600">Page {safePage} of {totalPages}</p>
  </section>

  <div class="grid gap-4 grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
    {posts.map((post, index) => (
      <article class="rounded-xl border border-neutral-200 p-4">
        {post.data.featuredImage && (
          <a href={`${base}/${post.slug}/`} class="block mb-3">
            <Image
              src={post.data.featuredImage}
              alt={post.data.title}
              class="w-full aspect-video object-cover rounded-lg"
              width={320}
              height={180}
              loading={index < 4 ? 'eager' : 'lazy'}
              fetchpriority={index < 2 ? 'high' : 'auto'}
            />
          </a>
        )}
        <p class="text-xs font-semibold uppercase tracking-wide text-neutral-500">
          {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
        </p>
        <h2 class="mt-2 text-lg font-semibold">
          <a class="text-blue-600 hover:text-blue-700" href={`${base}/${post.slug}/`}>
            {post.data.title}
          </a>
        </h2>
        {post.data.excerpt && (
          <p class="mt-2 text-sm text-neutral-600">{String(post.data.excerpt).replace(/\s+/g, ' ').trim()}</p>
        )}
      </article>
    ))}
  </div>

  <nav class="mt-10 flex items-center justify-between">
    <a class="text-sm font-semibold text-blue-600 hover:text-blue-700" href={prevUrl}>
      ← Prev
    </a>

    <div class="text-sm text-neutral-600">
      Page {safePage} / {totalPages}
    </div>

    {nextUrl ? (
      <a class="text-sm font-semibold text-blue-600 hover:text-blue-700" href={nextUrl}>
        Next →
      </a>
    ) : (
      <span class="text-sm text-neutral-400">Next →</span>
    )}
  </nav>
</BaseLayout>
