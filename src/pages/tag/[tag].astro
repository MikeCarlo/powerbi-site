---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const tags = new Set<string>();

  posts.forEach((post) => {
    post.data.tags?.forEach((t: string) => {
      const slug = t
        .toLowerCase()
        .replace(/\s+/g, '-')
        .replace(/[^a-z0-9-]/g, '');
      tags.add(slug);
    });
  });

  return Array.from(tags).map((tag) => ({ params: { tag } }));
}

const { tag } = Astro.params;

const slugifyTag = (value: string): string =>
  value
    .toLowerCase()
    .replace(/\s+/g, '-')
    .replace(/[^a-z0-9-]/g, '');

const posts = (await getCollection('blog'))
  .filter((post) => post.data.tags?.some((t) => slugifyTag(t) === tag))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .map((post) => ({
    ...post,
    slug: post.id.replace(/\/index\.mdx?$/, '').replace(/\.mdx?$/, '')
  }));

const displayName = posts[0]?.data.tags?.find((t) => slugifyTag(t) === tag) ?? tag;
---

<BaseLayout title={`${displayName} | PowerBI.tips`} description={`All posts tagged with ${displayName}`}>
  <section class="mb-12">
    <p class="text-sm font-semibold uppercase tracking-wide text-blue-600">Tag</p>
    <h1 class="mt-3 text-4xl font-semibold tracking-tight text-neutral-900">
      #{displayName}
    </h1>
    <p class="mt-4 text-lg text-neutral-600">
      {posts.length} {posts.length === 1 ? 'post' : 'posts'}
    </p>
  </section>

  <div class="grid gap-6">
    {posts.map((post) => {
      if (typeof post.data.featuredImage === 'string') {
        throw new Error(`featuredImage is a string for ${post.id}: ${post.data.featuredImage}`);
      }
      return (
      <article class="flex items-center gap-6 rounded-xl border border-neutral-200 p-4">
        {post.data.featuredImage && (
          <a href={`${base}/${post.slug}/`} class="shrink-0">
            <Image
              src={post.data.featuredImage}
              alt={post.data.title}
              width={180}
              height={101}
              class="h-[80px] w-[142px] rounded-lg object-cover"
            />
          </a>
        )}
        <div class="flex-1">
          <p class="text-xs font-semibold uppercase tracking-wide text-neutral-500">
            {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </p>
          <h2 class="mt-1 text-lg font-semibold">
            <a class="text-blue-600 hover:text-blue-700" href={`${base}/${post.slug}/`}>
              {post.data.title}
            </a>
          </h2>
          {post.data.excerpt && (
            <p class="mt-2 text-sm text-neutral-600 line-clamp-2">{post.data.excerpt}</p>
          )}
        </div>
      </article>
    );
    })}
  </div>

  <div class="mt-8">
    <a href={`${base}/tag/`} class="text-sm font-semibold text-blue-600 hover:text-blue-700">
      ← All Tags
    </a>
  </div>
</BaseLayout>
