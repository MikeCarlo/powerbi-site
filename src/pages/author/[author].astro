---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');

  // Extract all unique authors from all posts
  const authorMap = new Map();

  posts.forEach((post) => {
    post.data.authors?.forEach((author) => {
      const slug = author
        .toLowerCase()
        .replace(/\s+/g, '-')
        .replace(/[^a-z0-9-]/g, '');

      if (!authorMap.has(slug)) {
        authorMap.set(slug, { name: author, slug, posts: [] });
      }

      // IMPORTANT: `getStaticPaths` props must be serializable.
      // Content collection entries include non-serializable image metadata.
      // So we pass only the fields we need (including the resolved image `src`).
      authorMap.get(slug).posts.push({
        slug: post.id.replace(/\/index\.mdx?$/, '').replace(/\.mdx?$/, ''),
        title: post.data.title,
        date: post.data.date.toISOString(),
        excerpt: post.data.excerpt ?? null,
        featuredImageSrc: post.data.featuredImage?.src ?? null,
      });
    });
  });

  return Array.from(authorMap.values()).map((author) => ({
    params: { author: author.slug },
    props: {
      author: author.name,
      posts: author.posts.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()),
    },
  }));
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const { author, posts } = Astro.props;
---

<BaseLayout title={`${author} | PowerBI.tips`} description={`All posts by ${author}`}>
  <section class="mb-12">
    <p class="text-sm font-semibold uppercase tracking-wide text-blue-600">Author</p>
    <h1 class="mt-3 text-4xl font-semibold tracking-tight text-neutral-900">
      {author}
    </h1>
    <p class="mt-4 text-lg text-neutral-600">
      {posts.length} {posts.length === 1 ? 'post' : 'posts'}
    </p>
  </section>

  <div class="grid gap-6">
    {posts.map((post) => (
      <article class="flex items-center gap-6 rounded-xl border border-neutral-200 p-4">
        {post.featuredImageSrc && (
          <a href={`${base}/${post.slug}/`} class="shrink-0">
            <img
              src={post.featuredImageSrc}
              alt={post.title}
              width="180"
              height="101"
              loading="lazy"
              class="h-[80px] w-[142px] rounded-lg object-cover"
            />
          </a>
        )}
        <div class="flex-1">
          <p class="text-xs font-semibold uppercase tracking-wide text-neutral-500">
            {new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </p>
          <h2 class="mt-1 text-lg font-semibold">
            <a class="text-blue-600 hover:text-blue-700" href={`${base}/${post.slug}/`}>
              {post.title}
            </a>
          </h2>
          {post.excerpt && (
            <p class="mt-2 text-sm text-neutral-600 line-clamp-2">{post.excerpt}</p>
          )}
        </div>
      </article>
    ))}
  </div>
</BaseLayout>
